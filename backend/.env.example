# Anthropic credentials for the AI assistant. Options (resolved in this order):
#   1) Paste an API key here (get one at https://console.anthropic.com), OR
#   2) Leave blank + have Claude Code logged in (`npm i -g @anthropic-ai/claude-code`,
#      then run `claude` once) — JakIDE routes the assistant through `claude -p`, OR
#   3) Leave blank + use "Sign in with Anthropic" in the AI panel (OAuth via `ant`).
# If this key is set it takes precedence over the others.
ANTHROPIC_API_KEY=

# Model to use. Default: claude-opus-4-8. Other options: claude-sonnet-4-6, claude-haiku-4-5
ANTHROPIC_MODEL=claude-opus-4-8

# The project folder the IDE will open and operate on.
# Relative paths are resolved from the backend/ directory. Defaults to ./workspace (auto-created).
PROJECT_ROOT=./workspace

# Backend HTTP/WebSocket port
PORT=8787

# Optional: override the command runner / terminal allowlist (comma-separated, no spaces required)
# ALLOWED_COMMANDS=ls,cat,node,npm,git,python3,go,php
